  "keyFeatures": [
    "Multi-tenant architecture with automatic tenant scoping via BelongsToTenant trait",
    "Role-based access control (super-admin, director, profesor, estudiante, padre) using Spatie Laravel Permission",
    "Per-tenant module system (agenda, asistencia, circulares, anecdotario, biblioteca, estudiantes) with activation/deactivation",
    "Laravel Sanctum token-based authentication with token rotation on login",
    "Academic period management with course/section (paralelo) hierarchy",
    "Teacher assignment (asignacion docente) with weekly schedules",
    "Weighted-criteria grading system with grade book (libro de calificaciones) and averages",
    "Attendance tracking per class session with presence/absence/justified/late statuses",
    "Academic agenda with file attachments and student task submissions",
    "Parent portal for viewing children's grades, attendance, agenda, and anecdotal records",
    "Student portal for pending tasks, library, subjects, and schedule",
    "Circular (announcement) system with read-tracking and delivery statistics"
  ],
